
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Orders {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  nome          String
  telefone      String
  pedido        String
  observacoes   String
  paymaent      String
  createdAt     DateTime @default(now())

  @@map("orders")
}

model User {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  password      String
  active        Boolean @default(true)

  @@map("users")
}

model Products {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  price         Float
  description   String?
  isActive      Boolean
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("products")
}
