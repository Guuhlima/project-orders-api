
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["orders"]
}

model Orders {
  id            String   @id @default(uuid())
  nome          String
  telefone      String
  pedido        String
  observacoes   String
  paymaent      String
  createdAt     DateTime @default(now())

  @@map("orders")
  @@schema("orders")
}

model User {
  id       String @id @default(uuid())
  name     String
  password String
  active   Boolean @default(true)

  @@map("users")
  @@schema("orders")
}
