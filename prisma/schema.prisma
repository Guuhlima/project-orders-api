
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["orders"]
}

model Orders {
  id            String   @id @default(uuid())
  nome          String
  telefone      String
  pedido        String
  observacoes   String
  paymaent      String
  createdAt     DateTime @default(now())

  @@map("orders")
  @@schema("orders")
}

model User {
  id            String @id @default(uuid())
  name          String
  password      String
  active        Boolean @default(true)

  @@map("users")
  @@schema("orders")
}

model Products {
  id            String @id @default(uuid())
  name          String
  price         Decimal @db.Decimal(10, 2)
  description   String?
  isActive      Boolean
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("products")
  @@schema("orders")
}
